###########
### AWS ###
###########

# Cole a URL da fila SQS que você criou no console da AWS
AWS_SQS_URL=
# Nome da tabela DynamoDB que você criou
AWS_DYNAMODB_TABLE=ToggleMasterAnalytics
# Região dos seus serviços SQS e DynamoDB
AWS_REGION=
# URL para cada ECR registry de cada serviço 
AWS_AUTH_SERVICE_ECR=
AWS_EVALUATION_SERVICE_ECR=
AWS_ANALYTICS_SERVICE_ECR=
AWS_TARGETING_SERVICE_ECR=
AWS_FLAG_SERVICE_ECR=

####################
### auth-service ###
####################
# String de conexão do seu banco de dados PostgreSQL
AUTH_DATABASE_URL=postgres://auth_user:auth_password@auth-service-db:5432/auth_db
# Porta que o serviço irá rodar
AUTH_PORT=8001
# Chave mestra para criar novas chaves de API
MASTER_KEY=admin-secreto-123

# Dados de conexao do banco de dados
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=auth_password

##########################
### evaluation-service ###
##########################
# Porta que este serviço irá rodar
EVALUATION_PORT=8004
# URL do seu Redis local
REDIS_URL=redis://redis:6379
# URLs dos outros serviços
FLAG_SERVICE_URL=http://flag-service:8002
TARGETING_SERVICE_URL=http://targeting-service:8003
# Chave de API que você criou no passo 2
SERVICE_API_KEY=chave_secreta

#########################
### analytics-service ###
#########################
# Porta que este serviço (health check) irá rodar
ANALYTICS_PORT=8005

####################
### flag-service ###
####################
# String de conexão do seu banco de dados PostgreSQL
FLAG_DATABASE_URL=postgres://flag_user:flag_password@flag-service-db:5432/flags_db
# Porta que este serviço (flag-service) irá rodar
FLAG_PORT=8002
# URL do auth-service (que deve estar rodando na porta 8001)
AUTH_SERVICE_URL=http://auth-service:8001

# Dados de conexao do banco de dados
FLAG_POSTGRES_DB=flag_db
FLAG_POSTGRES_USER=flag_user
FLAG_POSTGRES_PASSWORD=flag_password

#########################
### targeting-service ###
#########################
# String de conexão do seu banco de dados PostgreSQL
TARGETING_DATABASE_URL=postgres://targeting_user:targeting_password@targeting-service-db:5432/targeting_db
# Porta que este serviço (targeting-service) irá rodar
TARGETING_PORT=8003
# URL do auth-service (que deve estar rodando na porta 8001)
AUTH_SERVICE_URL=http://auth-service:8001
# Dados de conexao do banco de dados
TARGETING_POSTGRES_DB=targeting_db
TARGETING_POSTGRES_USER=targeting_user
TARGETING_POSTGRES_PASSWORD=targeting_password